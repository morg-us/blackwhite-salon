# ─── Gerekli (Required) ─────────────────────────────────────────────────────

# PostgreSQL bağlantı dizesi / PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Oturum şifreleme anahtarı — rastgele uzun bir dize / Session encryption key
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Clerk Kimlik Doğrulama (Authentication) ─────────────────────────────────
# https://clerk.com adresinden alınır / Obtained from https://clerk.com
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ─── Stripe Ödemeler (Payments) ──────────────────────────────────────────────
# https://dashboard.stripe.com adresinden alınır / From https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Opsiyonel (Optional) ────────────────────────────────────────────────────

# Log seviyesi: trace | debug | info | warn | error (varsayılan: info)
LOG_LEVEL=info

# NetGSM SMS entegrasyonu (isteğe bağlı)
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=

# ─── Render.com tarafından otomatik sağlanır (Auto-provided by Render) ───────
# NODE_ENV=production   — Render tarafından ayarlanır
# PORT=10000            — Render tarafından ayarlanır
